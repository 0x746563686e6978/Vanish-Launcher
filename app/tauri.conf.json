{
  "$schema": "https://tauri.app/v1/config",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Vanish Launcher",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "fs": {
        "all": false,
        "writeFile": true,
        "readFile": true,
        "scope": ["$DESKTOP/**", "$HOME/**"]
      },
      "path": {
        "all": true
      },
      "window": {
        "all": false,
        "close": true,
        "maximize": false,
        "minimize": false,
        "startDragging": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.vanish.launcher",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    },
    "security": {
      "csp": "default-src 'self'; img-src https://cdn.discordapp.com 'self' data:; connect-src http://localhost:4000 https://discord.com; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": false,
        "title": "Vanish Launcher",
        "width": 900,
        "height": 580,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ]
  }
}
